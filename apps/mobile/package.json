{
  "name": "@my-codex-app/mobile",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "android:dev": "node ./scripts/ensure-android-local-direct.mjs && tauri android dev",
    "android:init": "tauri android init && node ./scripts/ensure-android-local-direct.mjs",
    "check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "build": "node ./scripts/ensure-android-local-direct.mjs && tauri android build --apk --aab",
